---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import NetworkHero from "../components/NetworkHero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import NewsList from "../components/NewsList.astro";

const featured = (await getCollection("publications", ({ data }) => !data.draft && data.featured))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

const news = (await getCollection("news", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);
---

<BaseLayout title="Mohsen Mosleh">
  <!-- Hero -->
  <NetworkHero>
    <section class="max-w-[76rem] mx-auto px-5 sm:px-8 py-24 sm:py-32 lg:py-40">
      <div class="max-w-3xl">
        <p class="eyebrow mb-4">University of Oxford</p>
        <h1 class="h-display text-4xl sm:text-6xl lg:text-7xl leading-[1.02] tracking-tight">
          Mohsen Mosleh
        </h1>
        <p class="mt-3 font-[Fraunces] text-xl sm:text-2xl text-[var(--color-ink-soft)] leading-snug">
          PhD, MIT Sloan
        </p>
        <p class="mt-6 text-[var(--color-ink-soft)] text-base sm:text-lg max-w-2xl leading-relaxed">
          I study the intersection of computational social science and cognitive psychology,
          with a focus on understanding information diffusion, belief formation, and
          network dynamics on social media platforms.
        </p>
        <p class="mt-3 text-[var(--color-ink-muted)] text-sm sm:text-base">
          Oxford Internet Institute &middot; Wolfson College &middot; MIT Sloan (Affiliate)
        </p>
        <div class="mt-9 flex flex-wrap gap-3">
          <a
            href="/publications"
            class="inline-flex items-center gap-2 px-5 py-3 rounded-full text-sm font-medium transition-colors"
            style="background: var(--color-ink); color: var(--color-cream);"
          >
            Publications <span aria-hidden="true">&rarr;</span>
          </a>
          <a
            href="https://scholar.google.com/citations?user=vVg9g0MAAAAJ"
            class="inline-flex items-center gap-2 px-5 py-3 rounded-full text-sm font-medium text-[var(--color-ink)] ring-1 ring-[var(--color-ink)]/15 hover:ring-[var(--color-ink)]/40 transition-colors"
          >
            Google Scholar
          </a>
        </div>
      </div>
    </section>
  </NetworkHero>

  <!-- Bio -->
  <section class="max-w-[76rem] mx-auto px-5 sm:px-8 pt-16 sm:pt-24">
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-start">
      <div class="lg:col-span-4" data-reveal>
        <p class="eyebrow mb-3">About</p>
        <h2 class="h-display text-3xl sm:text-4xl leading-tight">
          Research at the intersection of
          <span style="color: var(--color-ember);">computation</span> and
          <span style="color: var(--color-teal);">cognition</span>.
        </h2>
      </div>
      <div
        class="lg:col-span-8 text-[var(--color-ink-soft)] text-lg leading-relaxed space-y-5"
        data-reveal
        style="--reveal-delay:100ms"
      >
        <p>
          My research is at the intersection of computational (data) science and cognitive psychology.
          I use large-scale online experiments and observational data to study information diffusion,
          belief formation, and network formation on social media.
        </p>
        <p>
          I am particularly interested in understanding how the structure of social networks and
          platform design choices influence the spread of misinformation, political polarization,
          and collective behavior online.
        </p>
        <p>
          My work has been published in venues including <em class="text-[var(--color-ink)] not-italic font-medium">Nature</em>,
          <em class="text-[var(--color-ink)] not-italic font-medium">PNAS</em>,
          <em class="text-[var(--color-ink)] not-italic font-medium">Nature Communications</em>,
          and <em class="text-[var(--color-ink)] not-italic font-medium">Nature Human Behaviour</em>.
        </p>
      </div>
    </div>
  </section>

  <!-- Featured publications -->
  <section class="max-w-[76rem] mx-auto px-5 sm:px-8 mt-24 sm:mt-32">
    <div class="flex items-end justify-between gap-6 mb-8 sm:mb-12">
      <SectionHeader eyebrow="Selected work" title="Featured publications." />
      <a
        href="/publications"
        class="hidden sm:inline-flex items-center gap-2 text-sm font-medium text-[var(--color-ink)] hover:text-[var(--color-ember-dark)]"
      >
        All publications <span aria-hidden="true">&rarr;</span>
      </a>
    </div>

    {featured.length > 0 ? (
      <div class="grid gap-6 sm:grid-cols-2">
        {featured.map((p, i) => (
          <div
            data-reveal
            class="rounded-xl border hairline p-5 sm:p-6 transition-shadow duration-500"
            style={`background: var(--color-cream-card); box-shadow: var(--shadow-card); --reveal-delay:${i * 90}ms`}
          >
            <p class="eyebrow mb-2">{p.data.venue} &middot; {p.data.year}</p>
            <h3 class="h-display text-lg sm:text-xl leading-snug mb-3">{p.data.title}</h3>
            <p class="text-[var(--color-ink-muted)] text-sm mb-4">
              {p.data.authors.map((a, idx) => (
                <Fragment>
                  {idx > 0 && ", "}
                  {a.includes("Mosleh") ? <strong class="text-[var(--color-ink)]">{a}</strong> : a}
                </Fragment>
              ))}
            </p>
            {p.data.links && (
              <div class="flex gap-3 text-sm">
                {p.data.links.publisher && (
                  <a href={p.data.links.publisher} class="text-[var(--color-ember)] hover:underline underline-offset-2">
                    Publisher &nearr;
                  </a>
                )}
                {p.data.links.arxiv && (
                  <a href={p.data.links.arxiv} class="text-[var(--color-ember)] hover:underline underline-offset-2">
                    arXiv &nearr;
                  </a>
                )}
                {p.data.links.doi && (
                  <a href={p.data.links.doi} class="text-[var(--color-ember)] hover:underline underline-offset-2">
                    DOI &nearr;
                  </a>
                )}
              </div>
            )}
          </div>
        ))}
      </div>
    ) : (
      <p class="text-[var(--color-ink-muted)]">No publications yet.</p>
    )}

    <div class="mt-8 sm:hidden">
      <a
        href="/publications"
        class="inline-flex items-center gap-2 text-sm font-medium text-[var(--color-ink)] hover:text-[var(--color-ember-dark)]"
      >
        All publications <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </section>

  <!-- Latest news -->
  <section class="max-w-[76rem] mx-auto px-5 sm:px-8 mt-24 sm:mt-32 pb-8">
    <div class="flex items-end justify-between gap-6 mb-4">
      <SectionHeader eyebrow="Updates" title="Latest news." />
    </div>
    <div data-reveal>
      <NewsList items={news} />
    </div>
  </section>
</BaseLayout>
