---
/**
 * NetworkBackground — calm drifting network, fixed behind the entire page.
 * Deep Oxford-blue canvas with a handful of softly glowing nodes and
 * slowly rewiring edges. Pauses when tab hidden / respects
 * prefers-reduced-motion. Sits at z-index -1 behind all content.
 */
---

<!-- Oxford photo base layer -->
<div
  aria-hidden="true"
  class="fixed inset-0"
  style="z-index: -20; background: url('/img/oxford-bg.jpg') center center / cover no-repeat; background-color: var(--color-oxford);"
></div>

<!-- Dark Oxford-blue tint overlay for readability + brand colour -->
<div
  aria-hidden="true"
  class="fixed inset-0"
  style="z-index: -15; background: rgba(0, 25, 60, 0.72);"
></div>

<!-- Network animation sits on top of the photo at low opacity -->
<canvas
  id="network-canvas"
  aria-hidden="true"
  class="fixed inset-0 w-full h-full motion-reduce:hidden"
  style="z-index: -10; opacity: 0.85;"
></canvas>

<!-- Static fallback for reduced motion -->
<div
  aria-hidden="true"
  class="fixed inset-0 hidden motion-reduce:block"
  style="z-index: -10; background: radial-gradient(circle at 30% 20%, rgba(176,141,87,0.10), transparent 55%);"
></div>

<script is:inline>
  (() => {
    const canvas = document.getElementById("network-canvas");
    if (!canvas) return;
    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    if (prefersReduced) return;

    const ctx = canvas.getContext("2d");
    let width = 0;
    let height = 0;
    let dpr = Math.min(window.devicePixelRatio || 1, 2);

    // Oxford palette: gold, teal, terracotta, ivory — against deep Oxford-blue.
    const NODE_COLORS = ["#b08d57", "#5fa8a8", "#c97b53", "#e9e4d8"];
    const EDGE_COLOR = "rgba(233, 228, 216, 0.22)";

    const NODE_COUNT = 72;
    const CONNECT_DIST = 160;
    const DRIFT_SPEED = 0.12;

    const nodes = [];

    function rand(min, max) {
      return min + Math.random() * (max - min);
    }

    function seedNodes() {
      nodes.length = 0;
      for (let i = 0; i < NODE_COUNT; i++) {
        nodes.push({
          x: rand(0, width),
          y: rand(0, height),
          vx: rand(-DRIFT_SPEED, DRIFT_SPEED),
          vy: rand(-DRIFT_SPEED, DRIFT_SPEED),
          r: rand(1.8, 3.6),
          c: NODE_COLORS[Math.floor(Math.random() * NODE_COLORS.length)],
        });
      }
    }

    function resize() {
      width = window.innerWidth;
      height = window.innerHeight;
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = Math.floor(width * dpr);
      canvas.height = Math.floor(height * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      if (!nodes.length) seedNodes();
    }

    function step() {
      ctx.clearRect(0, 0, width, height);

      for (let i = 0; i < nodes.length; i++) {
        const n = nodes[i];
        n.x += n.vx;
        n.y += n.vy;
        if (n.x < -10) n.x = width + 10;
        if (n.x > width + 10) n.x = -10;
        if (n.y < -10) n.y = height + 10;
        if (n.y > height + 10) n.y = -10;
      }

      ctx.lineWidth = 1;
      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          const a = nodes[i];
          const b = nodes[j];
          const dx = a.x - b.x;
          const dy = a.y - b.y;
          const d2 = dx * dx + dy * dy;
          if (d2 < CONNECT_DIST * CONNECT_DIST) {
            const t = 1 - Math.sqrt(d2) / CONNECT_DIST;
            ctx.strokeStyle = EDGE_COLOR.replace(/[\d.]+\)$/, (m) =>
              (parseFloat(m) * t).toFixed(3) + ")",
            );
            ctx.beginPath();
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(b.x, b.y);
            ctx.stroke();
          }
        }
      }

      for (let i = 0; i < nodes.length; i++) {
        const n = nodes[i];
        ctx.fillStyle = n.c;
        ctx.beginPath();
        ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
        ctx.fill();
      }
    }

    let rafId = 0;
    let running = false;
    function loop() {
      step();
      rafId = requestAnimationFrame(loop);
    }
    function start() {
      if (running) return;
      running = true;
      loop();
    }
    function stop() {
      running = false;
      cancelAnimationFrame(rafId);
    }

    document.addEventListener("visibilitychange", () => {
      if (document.hidden) stop();
      else start();
    });

    window.addEventListener("resize", () => resize());

    resize();
    start();
  })();
</script>
