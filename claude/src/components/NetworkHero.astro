---
/**
 * GradientPulse background — slow breathing radial gradients in Oxford colours
 * layered over the Radcliffe Camera photo. No nodes or lines.
 * Pauses on tab hidden / respects prefers-reduced-motion.
 */
---

<!-- Oxford photo base layer -->
<div
  aria-hidden="true"
  class="fixed inset-0"
  style="z-index: -20; background: url('/img/oxford-bg.jpg') center center / cover no-repeat; background-color: var(--color-oxford);"
></div>

<!-- Dark Oxford-blue tint overlay -->
<div
  aria-hidden="true"
  class="fixed inset-0"
  style="z-index: -15; background: rgba(0, 25, 60, 0.72);"
></div>

<!-- Gradient pulse canvas -->
<canvas
  id="pulse-canvas"
  aria-hidden="true"
  class="fixed inset-0 w-full h-full motion-reduce:hidden"
  style="z-index: -10; opacity: 1;"
></canvas>

<script is:inline>
  (() => {
    const canvas = document.getElementById("pulse-canvas");
    if (!canvas) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    const ctx = canvas.getContext("2d");
    let W = 0, H = 0, dpr = 1;
    let t = 0;

    // Each orb: anchor position (0–1 relative), colour, phase offset, radius scale
    const ORBS = [
      { ax: 0.18, ay: 0.22, color: [176, 141,  87], phase: 0.00, rs: 0.55 }, // gold   — top-left
      { ax: 0.82, ay: 0.18, color: [ 95, 168, 168], phase: 1.05, rs: 0.50 }, // teal   — top-right
      { ax: 0.50, ay: 0.62, color: [  0,  33,  90], phase: 2.10, rs: 0.70 }, // oxford — centre
      { ax: 0.12, ay: 0.78, color: [201, 123,  83], phase: 3.14, rs: 0.45 }, // terra  — bottom-left
      { ax: 0.88, ay: 0.72, color: [176, 141,  87], phase: 4.19, rs: 0.48 }, // gold   — bottom-right
    ];

    function resize() {
      W = window.innerWidth;
      H = window.innerHeight;
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width  = Math.floor(W * dpr);
      canvas.height = Math.floor(H * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    function draw() {
      ctx.clearRect(0, 0, W, H);

      for (const orb of ORBS) {
        // Pulse: radius breathes ±12% over ~8 s, each orb offset by phase
        const breathe = 1 + 0.12 * Math.sin(t * 0.00045 + orb.phase);
        const r = Math.min(W, H) * orb.rs * breathe;

        // Orb drifts gently in a small Lissajous around its anchor
        const drift = Math.min(W, H) * 0.04;
        const cx = W * orb.ax + drift * Math.sin(t * 0.00030 + orb.phase);
        const cy = H * orb.ay + drift * Math.cos(t * 0.00022 + orb.phase * 1.3);

        const [r0, g0, b0] = orb.color;
        const grad = ctx.createRadialGradient(cx, cy, 0, cx, cy, r);
        grad.addColorStop(0,   `rgba(${r0},${g0},${b0},0.55)`);
        grad.addColorStop(0.5, `rgba(${r0},${g0},${b0},0.25)`);
        grad.addColorStop(1,   `rgba(${r0},${g0},${b0},0)`);

        ctx.fillStyle = grad;
        ctx.beginPath();
        ctx.ellipse(cx, cy, r, r * 0.75, 0, 0, Math.PI * 2);
        ctx.fill();
      }
    }

    let rafId = 0;
    let running = false;

    function loop(ts) {
      t = ts;
      draw();
      rafId = requestAnimationFrame(loop);
    }
    function start() { if (running) return; running = true; rafId = requestAnimationFrame(loop); }
    function stop()  { running = false; cancelAnimationFrame(rafId); }

    document.addEventListener("visibilitychange", () => document.hidden ? stop() : start());
    window.addEventListener("resize", resize);

    resize();
    start();
  })();
</script>
