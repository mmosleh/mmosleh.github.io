---
/**
 * NetworkHero — drifting network animation behind the page header.
 * Dark Oxford-blue canvas with softly glowing nodes and rewiring edges.
 * Pauses off-screen / when tab hidden / respects prefers-reduced-motion.
 */
---

<div class="relative isolate overflow-hidden" data-network-host>
  <canvas
    id="network-canvas"
    aria-hidden="true"
    class="absolute inset-0 w-full h-full motion-reduce:hidden"
  ></canvas>

  <!-- Static fallback for reduced motion -->
  <div
    aria-hidden="true"
    class="absolute inset-0 hidden motion-reduce:block"
    style="background: radial-gradient(circle at 30% 30%, rgba(176,141,87,0.15), transparent 60%), var(--color-oxford);"
  ></div>

  <div class="relative">
    <slot />
  </div>
</div>

<script is:inline>
  (() => {
    const canvas = document.getElementById("network-canvas");
    if (!canvas) return;
    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    if (prefersReduced) return;

    const ctx = canvas.getContext("2d");
    let width = 0;
    let height = 0;
    let dpr = Math.min(window.devicePixelRatio || 1, 2);

    // Oxford palette: gold, teal, terracotta, ivory — against deep Oxford-blue.
    const NODE_COLORS = ["#b08d57", "#5fa8a8", "#c97b53", "#e9e4d8"];
    const EDGE_COLOR = "rgba(233, 228, 216, 0.16)";

    const NODE_COUNT = 46;
    const CONNECT_DIST = 150;
    const DRIFT_SPEED = 0.16;

    const nodes = [];

    function rand(min, max) {
      return min + Math.random() * (max - min);
    }

    // ~1-in-6 nodes is a "hub" — bigger, with a soft pulsing glow halo,
    // evoking an influential account in a social graph / an active unit
    // in a neural net.
    function seedNodes() {
      nodes.length = 0;
      for (let i = 0; i < NODE_COUNT; i++) {
        const isHub = Math.random() < 0.16;
        nodes.push({
          x: rand(0, width),
          y: rand(0, height),
          vx: rand(-DRIFT_SPEED, DRIFT_SPEED),
          vy: rand(-DRIFT_SPEED, DRIFT_SPEED),
          r: isHub ? rand(4, 6) : rand(1.4, 3),
          hub: isHub,
          phase: rand(0, Math.PI * 2),
          c: NODE_COLORS[Math.floor(Math.random() * NODE_COLORS.length)],
        });
      }
    }

    // Pulses of "shared information" travel along a handful of edges at
    // any moment — small bright dots gliding from node to node.
    const MAX_PULSES = 10;
    const pulses = [];
    function maybeSpawnPulse(a, b) {
      if (pulses.length >= MAX_PULSES || Math.random() > 0.0035) return;
      pulses.push({ a, b, t: 0, speed: rand(0.006, 0.014), c: a.c });
    }

    function resize() {
      const rect = canvas.getBoundingClientRect();
      width = rect.width;
      height = rect.height;
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = Math.floor(width * dpr);
      canvas.height = Math.floor(height * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      if (!nodes.length) seedNodes();
    }

    function step() {
      ctx.clearRect(0, 0, width, height);

      for (let i = 0; i < nodes.length; i++) {
        const n = nodes[i];
        n.x += n.vx;
        n.y += n.vy;
        if (n.x < -10) n.x = width + 10;
        if (n.x > width + 10) n.x = -10;
        if (n.y < -10) n.y = height + 10;
        if (n.y > height + 10) n.y = -10;
      }

      ctx.lineWidth = 1;
      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          const a = nodes[i];
          const b = nodes[j];
          const dx = a.x - b.x;
          const dy = a.y - b.y;
          const d2 = dx * dx + dy * dy;
          if (d2 < CONNECT_DIST * CONNECT_DIST) {
            const t = 1 - Math.sqrt(d2) / CONNECT_DIST;
            ctx.strokeStyle = EDGE_COLOR.replace(/[\d.]+\)$/, (m) =>
              (parseFloat(m) * t).toFixed(3) + ")",
            );
            ctx.beginPath();
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(b.x, b.y);
            ctx.stroke();
            maybeSpawnPulse(a, b);
          }
        }
      }

      // Glowing halos behind hub nodes — gentle pulse, like an active
      // account / firing neuron.
      const now = performance.now() * 0.001;
      for (let i = 0; i < nodes.length; i++) {
        const n = nodes[i];
        if (!n.hub) continue;
        const pulse = 0.55 + 0.45 * Math.sin(now * 1.4 + n.phase);
        const haloR = n.r * (3.4 + pulse * 1.6);
        const grad = ctx.createRadialGradient(n.x, n.y, 0, n.x, n.y, haloR);
        grad.addColorStop(0, n.c + "55");
        grad.addColorStop(1, n.c + "00");
        ctx.fillStyle = grad;
        ctx.beginPath();
        ctx.arc(n.x, n.y, haloR, 0, Math.PI * 2);
        ctx.fill();
      }

      // Information pulses gliding along edges.
      for (let i = pulses.length - 1; i >= 0; i--) {
        const p = pulses[i];
        p.t += p.speed;
        if (p.t >= 1) {
          pulses.splice(i, 1);
          continue;
        }
        const x = p.a.x + (p.b.x - p.a.x) * p.t;
        const y = p.a.y + (p.b.y - p.a.y) * p.t;
        const fade = Math.sin(Math.PI * p.t); // fade in/out along the trip
        ctx.fillStyle = p.c;
        ctx.globalAlpha = 0.85 * fade;
        ctx.beginPath();
        ctx.arc(x, y, 1.8, 0, Math.PI * 2);
        ctx.fill();
        ctx.globalAlpha = 1;
      }

      // Nodes on top.
      for (let i = 0; i < nodes.length; i++) {
        const n = nodes[i];
        ctx.fillStyle = n.c;
        ctx.beginPath();
        ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2);
        ctx.fill();
      }
    }

    let rafId = 0;
    let running = false;
    function loop() {
      step();
      rafId = requestAnimationFrame(loop);
    }
    function start() {
      if (running) return;
      running = true;
      loop();
    }
    function stop() {
      running = false;
      cancelAnimationFrame(rafId);
    }

    const host = canvas.closest("[data-network-host]") || canvas;
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) start();
          else stop();
        });
      },
      { threshold: 0 },
    );
    io.observe(host);

    document.addEventListener("visibilitychange", () => {
      if (document.hidden) stop();
      else start();
    });

    window.addEventListener("resize", () => resize());

    resize();
    start();
  })();
</script>
