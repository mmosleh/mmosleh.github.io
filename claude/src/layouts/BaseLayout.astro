---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Mohsen Mosleh",
  description = "Mohsen Mosleh — researcher working on social networks, misinformation, and computational social science.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <title>{title} · Mohsen Mosleh</title>
  </head>
  <body class="antialiased">
    <slot />
  </body>
</html>
